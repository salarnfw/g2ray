{
  "name": "Xray Codespace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".devcontainer"
  },
  "postStartCommand": "./start.sh",
  "forwardPorts": [443],
  "remoteUser": "root",
  "portsAttributes": {
    "443": {
      "label": "Xray HTTPS",
      "onAutoForward": "openBrowser"
    }
  }
}
