{
  "name": "Xray Codespace",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "postStartCommand": "bash /workspaces/g2ray/.devcontainer/start.sh",
  "forwardPorts": [443],
  "remoteUser": "root",
  "portsAttributes": {
    "443": {
      "label": "Xray HTTPS",
      "onAutoForward": "openBrowser"
    }
  }
}
